{
  "components": {
    "input": {
      "description": "Text input field component with variants and states",
      "base": {
        "padding": "{spacing.tokens.2} {spacing.tokens.3}",
        "fontSize": "14px",
        "lineHeight": "20px",
        "border": "1px solid {colors.border.default}",
        "borderRadius": "{borderRadius.tokens.md}",
        "transition": "{motion.transitions.all}",
        "fontFamily": "{typography.fontFamilies.primary}",
        "backgroundColor": "{colors.background.primary}"
      },
      "variants": {
        "default": {
          "border": "1px solid {colors.border.default}",
          "color": "{colors.text.primary}"
        },
        "filled": {
          "backgroundColor": "{colors.background.secondary}",
          "border": "1px solid {colors.border.default}",
          "color": "{colors.text.primary}"
        },
        "flushed": {
          "backgroundColor": "transparent",
          "border": "none",
          "borderBottom": "2px solid {colors.border.default}",
          "borderRadius": "0",
          "paddingLeft": "0",
          "paddingRight": "0"
        }
      },
      "sizes": {
        "sm": {
          "padding": "{spacing.tokens.1} {spacing.tokens.2}",
          "fontSize": "12px",
          "minHeight": "28px"
        },
        "md": {
          "padding": "{spacing.tokens.2} {spacing.tokens.3}",
          "fontSize": "14px",
          "minHeight": "36px"
        },
        "lg": {
          "padding": "{spacing.tokens.3} {spacing.tokens.4}",
          "fontSize": "16px",
          "minHeight": "44px"
        }
      },
      "states": {
        "default": {
          "borderColor": "{colors.border.default}",
          "color": "{colors.text.primary}"
        },
        "hover": {
          "borderColor": "{colors.border.default}",
          "boxShadow": "{shadows.components.input.default}"
        },
        "focus": {
          "borderColor": "{colors.border.focus}",
          "boxShadow": "{shadows.components.input.focus}",
          "outline": "none"
        },
        "disabled": {
          "backgroundColor": "{colors.background.secondary}",
          "borderColor": "{colors.border.disabled}",
          "color": "{colors.text.disabled}",
          "cursor": "not-allowed",
          "opacity": 0.5
        },
        "error": {
          "borderColor": "{colors.border.error}",
          "boxShadow": "{shadows.components.input.error}"
        },
        "success": {
          "borderColor": "{colors.semantic.success}",
          "boxShadow": "{shadows.focusSuccess}"
        }
      },
      "placeholder": {
        "color": "{colors.text.tertiary}",
        "opacity": 1
      }
    },
    "textarea": {
      "description": "Textarea component for multi-line text input",
      "base": {
        "padding": "{spacing.tokens.3} {spacing.tokens.3}",
        "fontSize": "14px",
        "lineHeight": "20px",
        "border": "1px solid {colors.border.default}",
        "borderRadius": "{borderRadius.tokens.md}",
        "fontFamily": "{typography.fontFamilies.primary}",
        "minHeight": "100px",
        "resize": "vertical",
        "transition": "{motion.transitions.all}"
      }
    },
    "select": {
      "description": "Select dropdown component",
      "base": {
        "padding": "{spacing.tokens.2} {spacing.tokens.3}",
        "fontSize": "14px",
        "border": "1px solid {colors.border.default}",
        "borderRadius": "{borderRadius.tokens.md}",
        "backgroundColor": "{colors.background.primary}",
        "cursor": "pointer",
        "appearance": "none",
        "backgroundImage": "url(\"data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e\")",
        "backgroundRepeat": "no-repeat",
        "backgroundPosition": "right {spacing.tokens.2} center",
        "backgroundSize": "1.5em 1.5em",
        "paddingRight": "2.5rem"
      }
    },
    "checkbox": {
      "description": "Checkbox component",
      "size": "20px",
      "borderRadius": "{borderRadius.tokens.xs}",
      "border": "2px solid {colors.border.default}",
      "backgroundColor": "{colors.background.primary}",
      "states": {
        "checked": {
          "backgroundColor": "{colors.semantic.primary}",
          "borderColor": "{colors.semantic.primary}"
        },
        "focus": {
          "boxShadow": "{shadows.focus}"
        }
      }
    },
    "radio": {
      "description": "Radio button component",
      "size": "20px",
      "borderRadius": "50%",
      "border": "2px solid {colors.border.default}",
      "backgroundColor": "{colors.background.primary}",
      "states": {
        "checked": {
          "borderColor": "{colors.semantic.primary}"
        }
      }
    },
    "toggle": {
      "description": "Toggle/switch component",
      "width": "44px",
      "height": "24px",
      "borderRadius": "12px",
      "backgroundColor": "{colors.gray300}",
      "states": {
        "on": {
          "backgroundColor": "{colors.semantic.primary}"
        },
        "off": {
          "backgroundColor": "{colors.gray300}"
        }
      }
    }
  }
}
